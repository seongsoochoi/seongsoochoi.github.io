---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
  description: 'Contact Seongsoo Choi at MetaIntelligence.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Contact Seongsoo Choi"
    subtitle="For professional inquiries related to integrated AI solutions, R&amp;D collaboration, and MetaIntelligence."
    callToAction={{
      text: 'Send Email',
      href: 'mailto:choi@metaintelligence.co.kr',
      icon: 'tabler:mail',
    }}
  />

  <Features2
    title="Professional Contact"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'choi@metaintelligence.co.kr',
        icon: 'tabler:mail',
      },
      {
        title: 'Role',
        description: 'CEO / President, Integrated AI Solution Architect',
        icon: 'tabler:user-star',
      },
      {
        title: 'Organization',
        description: 'MetaIntelligence Inc.',
        icon: 'tabler:building',
      },
      {
        title: 'Location',
        description: 'Hwaseong, Gyeonggi-do, Republic of Korea',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
