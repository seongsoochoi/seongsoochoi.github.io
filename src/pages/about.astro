---
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import metaLogoRaw from '~/assets/images/logo_metaintelligence.svg?raw';

const metadata = {
  title: 'About Seongsoo Choi',
  description:
    'About Seongsoo Choi, CEO of MetaIntelligence, with work in applied AI systems and physics-based research.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="About"
    image={{
      src: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Networked technology landscape',
    }}
  >
    <Fragment slot="title">
      About Seongsoo Choi
    </Fragment>

    <Fragment slot="subtitle">
      Founder, CEO, and president of MetaIntelligence. Work areas include applied AI systems, physics-based modeling,
      high-performance computing, and public R&amp;D projects.
    </Fragment>
  </Hero>

  <Stats
    title="Background"
    stats={[
      { title: 'MetaIntelligence', amount: '2021' },
      { title: 'POSTECH Ph.D.', amount: '2016' },
      { title: 'Applied Systems', amount: 'AI' },
      { title: 'NRF Projects', amount: '7' },
    ]}
  />

  <Features3
    title="Areas of Work"
    subtitle="A short view of the work represented in the resume."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'AI Systems',
        description:
          'Plans systems that combine natural-language processing, vision, optimization, and domain workflows.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'Physics and Computing',
        description:
          'Background in mathematical physics, computational physics, condensed matter theory, quantum many-body theory, and supercomputing.',
        icon: 'tabler:atom',
      },
      {
        title: 'R&D Projects',
        description:
          'Leads research projects, documentation, partner coordination, and implementation planning.',
        icon: 'tabler:chart-arrows-vertical',
      },
    ]}
  />

  <Features
    id="approach"
    tagline="Method"
    title="Working Approach"
    subtitle="Keep the problem structure explicit, then choose the model and implementation."
    items={[
      {
        title: 'Modeling',
        description:
          'Clarifies assumptions and mathematical structure before implementation decisions are made.',
        icon: 'tabler:math-function',
      },
      {
        title: 'Representation',
        description:
          'NLP research centers on partitioning natural-language datasets, deriving digital trees, optimizing parameters, and identifying invariant basis sets.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Operation',
        description:
          'Designs AI as a workflow: data intake, diagnosis, explanation, and reporting.',
        icon: 'tabler:settings-automation',
      },
    ]}
  />

  <Content
    isReversed
    tagline="Highlights"
    title="Selected Work"
    subtitle="Representative items from the resume."
    items={[
      {
        title: 'Registered Patent',
        description:
          'Sole inventor of Korean Patent No. 10-2573563, a natural-language data analysis system and method.',
      },
      {
        title: 'Government R&D',
        description:
          'Principal investigator for NRF research-analysis projects, including repeated project orders.',
      },
      {
        title: 'Academic Publication',
        description:
          'Published mathematical-physics research on primes and nontrivial zeros in the Riemann hypothesis in Journal of Mathematical Physics.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Research and project work
      </h3>
      The work combines academic physics, applied AI, patent work, public R&D, and company operations at
      MetaIntelligence.
    </Fragment>

    <Fragment slot="image">
      <div class="rounded-lg border border-black/10 bg-white p-8 shadow-lg dark:border-white/10 dark:bg-slate-900">
        <div class="mx-auto max-w-xs [&>svg]:h-auto [&>svg]:w-full" set:html={metaLogoRaw} />
        <div class="mt-6 grid grid-cols-3 gap-3 text-center">
          <div>
            <div class="text-sm font-bold text-gray-900 dark:text-white">Patent</div>
            <div class="mt-1 text-xs text-muted dark:text-slate-400">10-2573563</div>
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900 dark:text-white">NRF</div>
            <div class="mt-1 text-xs text-muted dark:text-slate-400">7 projects</div>
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900 dark:text-white">JMP</div>
            <div class="mt-1 text-xs text-muted dark:text-slate-400">2012</div>
          </div>
        </div>
      </div>
    </Fragment>
  </Content>

  <Features2
    title="Contact"
    tagline="Connect"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'choi@metaintelligence.co.kr',
        icon: 'tabler:mail',
      },
      {
        title: 'Organization',
        description: 'MetaIntelligence Inc.',
        icon: 'tabler:building',
      },
    ]}
  />
</Layout>
