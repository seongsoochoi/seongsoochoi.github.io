---
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Me',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About Me"
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Woohyun Kim Workspace',
    }}
  >
    <Fragment slot="title">
      Architecting the Future with <br />
      <span class="text-accent dark:text-white"> 3D Graphics & AI</span>
    </Fragment>

    <Fragment slot="subtitle">
      I am an Executive Director and Senior Software Engineer specializing in Computer Graphics and Generative AI.
      My journey bridges mathematical theory with high-performance engineering, creating tools that empower users and systems that scale.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Engineering Journey"
    stats={[
      { title: 'Years Experience', amount: '10+' },
      { title: 'Key Projects', amount: '15+' },
      { title: 'Awards & Patents', amount: '5+' },
      { title: 'Tech Articles', amount: '20+' },
    ]}
  />

  <!-- Features3 Widget (Focus Areas) ************** -->

  <Features3
    title="Core Focus Areas"
    subtitle="My career has been defined by a deep dive into these three pillars of technology."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Graphics Engineering',
        description:
          'From low-level OpenGL optimizations to high-level rendering engines. Built creative tools like Wonderland and Watch Face Studio, among others.',
        icon: 'tabler:cube',
      },
      {
        title: 'Generative AI & R&D',
        description:
          'Leading research and development at MetaIntelligence. Focusing on large-scale model integration and practical AI applications, including MVI for manufacturing defect detection.',
        icon: 'tabler:brain',
      },
      {
        title: 'System Architecture',
        description:
          'Designing robust end-to-end architectures. I believe in building systems that are not just functional but maintainable and scalable.',
        icon: 'tabler:sitemap',
      },
    ]}
  />

  <!-- Features Widget (Philosophy) ****************** -->

  <Features
    id="philosophy"
    tagline="Values"
    title="My Philosophy"
    subtitle="I believe that great software is born from a clear understanding of the problem, not just the tools used to solve it."
    items={[
      {
        title: 'Language Agnosticism',
        description:
          'I view programming languages as tools, not identities. Whether it is C++, Python, or Kotlin, I focus on the algorithmic logic and architectural integrity appropriate for the problem at hand.',
        icon: 'tabler:code',
      },
      {
        title: 'Mathematical Foundation',
        description:
          'With a background in Applied Mathematics, I approach software challenges with first-principles thinking, ensuring optimization and logic are mathematically sound.',
        icon: 'tabler:math-function',
      },
      {
        title: 'Macro-Optimization',
        description:
          'True performance comes from seeing the forest, not just the trees. I prioritize system-wide architectural optimization over premature micro-optimization.',
        icon: 'tabler:zoom-check',
      },
    ]}
  />

  <!-- Content Widget (Achievements) ****************** -->

  <Content
    isReversed
    tagline="Highlights"
    title="Key Achievements"
    subtitle="Major milestones from my career at Samsung Electronics and beyond."
    items={[
      {
        title: 'Creative Platforms',
        description:
          'Architected and developed "Wonderland" (Wallpaper Creator) and "Watch Face Studio" (Wear OS Tool), empowering millions of Galaxy users to express their creativity.',
      },
      {
        title: 'Innovation & Patents',
        description:
          'Developed "Runtime Gradient Blur" technology (Patent Grade A) and led the implementation of AI Effects for the Galaxy S25 series.',
      },
      {
        title: 'Recognition & Awards',
        description:
          'Recipient of the Minister Award (Grand Prize) at K-Hackathon and Silver Award at KIT Engineering Fair for excellence in software engineering.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Achievements Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Proven Track Record</h3>
    </Fragment>
  </Content>

  <!-- Features2 Widget (Contact) ************** -->

  <Features2
    title="Connect with Me"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'artrointel@gmail.com',
        icon: 'tabler:mail',
      },
      {
        title: 'GitHub',
        description: 'github.com/artrointel',
        icon: 'tabler:brand-github',
      },
    ]}
  />
</Layout>
