---
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import metaLogoRaw from '~/assets/images/logo_metaintelligence.svg?raw';

const metadata = {
  title: 'About Seongsoo Choi',
  description:
    'About Seongsoo Choi, CEO of MetaIntelligence and Integrated AI Solution Architect with a Ph.D. in Physics.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="About"
    image={{
      src: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Networked technology landscape',
    }}
  >
    <Fragment slot="title">
      First-Principles AI for <br />
      <span class="text-accent dark:text-white">Industry and Research</span>
    </Fragment>

    <Fragment slot="subtitle">
      Seongsoo Choi is the founder, CEO, and president of MetaIntelligence. His work combines physics-informed
      modeling, integrated AI architecture, high-performance computing, and R&amp;D leadership.
    </Fragment>
  </Hero>

  <Stats
    title="Professional Foundation"
    stats={[
      { title: 'Company Founded', amount: '2021' },
      { title: 'POSTECH Physics Ph.D.', amount: '2016' },
      { title: 'Solution Architect', amount: 'AI' },
      { title: 'NRF Projects', amount: '7' },
    ]}
  />

  <Features3
    title="Focus Areas"
    subtitle="Capabilities from the resume, organized around AI architecture, physics, and R&amp;D commercialization."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'AI Architecture',
        description:
          'Designs integrated AI systems that combine natural-language processing, vision, optimization, and domain workflows.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'Physics and HPC',
        description:
          'Brings a background in mathematical physics, computational physics, condensed matter theory, quantum many-body theory, and supercomputing.',
        icon: 'tabler:atom',
      },
      {
        title: 'R&D Commercialization',
        description:
          'Turns patent-backed research into AI solutions while leading corporate strategy, research-center operations, and government R&D programs.',
        icon: 'tabler:chart-arrows-vertical',
      },
    ]}
  />

  <Features
    id="approach"
    tagline="Approach"
    title="How the Work Is Framed"
    subtitle="The same method appears across NLP, vision AI, and manufacturing intelligence: start from structure, then build the system."
    items={[
      {
        title: 'First-Principles Modeling',
        description:
          'Problems are decomposed into mathematical structure before implementation decisions are made.',
        icon: 'tabler:math-function',
      },
      {
        title: 'Invariant Representation',
        description:
          'NLP research centers on partitioning natural-language datasets, deriving digital trees, optimizing parameters, and identifying invariant basis sets.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Operational AI',
        description:
          'AI systems are treated as operating architectures, not isolated models: data intake, diagnosis, explanation, and reporting are designed together.',
        icon: 'tabler:settings-automation',
      },
    ]}
  />

  <Content
    isReversed
    tagline="Highlights"
    title="Selected Achievements"
    subtitle="A concise view of the major career signals from the resume."
    items={[
      {
        title: 'Registered Patent',
        description:
          'Sole inventor of Korean Patent No. 10-2573563, a first-principles natural-language data analysis system and method.',
      },
      {
        title: 'Government R&D Leadership',
        description:
          'Principal investigator for Korea NRF projects, including four consecutive years of re-ordered work and seven cumulative projects.',
      },
      {
        title: 'Academic Publication',
        description:
          'Published mathematical-physics research on primes and nontrivial zeros in the Riemann hypothesis in Journal of Mathematical Physics.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Research depth with delivery ownership
      </h3>
      The profile spans fundamental physics, AI methods, patents, public R&D, and executive responsibility at
      MetaIntelligence.
    </Fragment>

    <Fragment slot="image">
      <div class="rounded-lg border border-black/10 bg-white p-8 shadow-lg dark:border-white/10 dark:bg-slate-900">
        <div class="mx-auto max-w-xs [&>svg]:h-auto [&>svg]:w-full" set:html={metaLogoRaw} />
        <div class="mt-6 grid grid-cols-3 gap-3 text-center">
          <div>
            <div class="text-sm font-bold text-gray-900 dark:text-white">Patent</div>
            <div class="mt-1 text-xs text-muted dark:text-slate-400">10-2573563</div>
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900 dark:text-white">NRF</div>
            <div class="mt-1 text-xs text-muted dark:text-slate-400">7 projects</div>
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900 dark:text-white">JMP</div>
            <div class="mt-1 text-xs text-muted dark:text-slate-400">2012</div>
          </div>
        </div>
      </div>
    </Fragment>
  </Content>

  <Features2
    title="Contact"
    tagline="Connect"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'choi@metaintelligence.co.kr',
        icon: 'tabler:mail',
      },
      {
        title: 'Organization',
        description: 'MetaIntelligence Inc.',
        icon: 'tabler:building',
      },
    ]}
  />
</Layout>
