---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'Woohyun Kim | 3D Graphics & AI Engineer',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title">
      <span class="text-black dark:text-black highlight">Woohyun Kim</span>
      <br />
      <span class="text-2xl font-light tracking-wide text-gray-600 dark:text-gray-400">
        Executive Director & Senior Engineer
      </span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Specialist in <b>3D Graphics</b> and <b>Deep Learning (GenAI)</b>.
        <br/>
        Architecting robust systems by bridging mathematical theory with high-performance engineering.
      </span>
    </Fragment>
  </Hero>

  <!-- Features Widget (Skills) *************** -->

  <Features
    id="competencies"
    tagline="Core Competencies"
    title="Technical Expertise"
    subtitle="Combining mathematical precision with creative engineering to build next-generation systems."
    items={[
      {
        title: '3D Graphics & Rendering',
        description:
          'Extensive experience with OpenGL ES, GLSL, and rendering pipelines, from low-level optimizations to high-level creative tools.',
        icon: 'tabler:cube',
      },
      {
        title: 'Generative AI & DL',
        description:
          'Leading R&D in Generative AI and Deep Learning at MetaIntelligence, applying cutting-edge models to practical solutions.',
        icon: 'tabler:brain',
      },
      {
        title: 'System Architecture',
        description:
          'Designing robust, scalable end-to-end systems with a macro-level perspective on performance and stability.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'Mathematical R&D',
        description:
          'Leveraging a strong background in Applied Mathematics to solve complex algorithmic challenges in graphics and AI.',
        icon: 'tabler:math-function',
      },
      {
        title: 'Performance Engineering',
        description:
          'Deep expertise in GPU profiling, memory management, and system optimization using industry-standard tools.',
        icon: 'tabler:activity',
      },
      {
        title: 'Platform Engineering',
        description:
          'Experience in building creative platforms and SDKs like Watch Face Studio, empowering creators globally.',
        icon: 'tabler:tools',
      },
    ]}
  />

  <!-- Content Widget (Philosophy) **************** -->

  <Content
    isReversed
    tagline="Philosophy"
    title="Engineering Philosophy"
    items={[
      {
        title: 'Language Agnosticism',
        description:
          'Tools change, but logic remains. I prioritize algorithmic thinking and architectural integrity over syntax dependencies, allowing for seamless adaptation to any technology stack.',
      },
      {
        title: 'The Big Picture',
        description:
          'True optimization comes from understanding the entire system. I focus on designing architectures that are not only efficient today but scalable for tomorrow.',
      },
      {
        title: 'Innovation through Basics',
        description:
          'My approach is rooted in fundamental principles—mathematics and computer science theory—which serve as the bedrock for innovative solutions in AI and Graphics.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Engineering Philosophy',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">From Mathematics to Meta-Systems</h3>
      Building the future requires a solid foundation.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- BlogLatestPosts Widget ******* -->

  <BlogLatestPosts
    title="Latest Insights"
    information={`Sharing thoughts on technology, architecture, and the future of AI.`}
  />

</Layout>
