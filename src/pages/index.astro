---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import metaLogoRaw from '~/assets/images/logo_metaintelligence.svg?raw';

const metadata = {
  title: 'Seongsoo Choi | AI Systems and Physics',
  ignoreTitleTemplate: true,
  description:
    'Seongsoo Choi is CEO of MetaIntelligence, working on applied AI systems with a background in physics.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="AI Systems and Physics"
    actions={[
      { variant: 'primary', text: 'View Resume', href: '/resume', icon: 'tabler:file-text' },
      { text: 'Contact', href: 'mailto:choi@metaintelligence.co.kr', icon: 'tabler:mail' },
    ]}
  >
    <Fragment slot="title">
      <span class="text-gray-900 dark:text-gray-200">Seongsoo Choi</span>
      <br />
      <span class="text-2xl font-light tracking-wide text-gray-600 dark:text-gray-400">
        CEO, MetaIntelligence
      </span>
    </Fragment>

    <Fragment slot="subtitle">
      Works on applied AI systems for language, vision, manufacturing data, and research analysis, with a background in
      physics.
    </Fragment>
  </Hero>

  <Stats
    title="Profile"
    stats={[
      { title: 'Founded MetaIntelligence', amount: '2021' },
      { title: 'Registered Patent', amount: '1' },
      { title: 'NRF Projects', amount: '7' },
      { title: 'POSTECH Physics', amount: 'PhD' },
    ]}
  />

  <Features
    id="competencies"
    tagline="Work"
    title="Main Areas"
    subtitle="Applied AI work across language, vision, manufacturing data, and research analysis."
    items={[
      {
        title: 'AI System Design',
        description:
          'Designs workflows that connect data processing, model logic, review, and reporting.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'Physics-Based Modeling',
        description:
          'Uses physics and mathematical structure when they are relevant to modeling and analysis.',
        icon: 'tabler:atom',
      },
      {
        title: 'Natural Language Analysis',
        description:
          'Patent work covers data partitioning, digital-tree construction, parameter optimization, and invariant-basis methods.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Manufacturing Vision',
        description:
          'Work includes defect detection, classification, and inspection support for manufacturing environments.',
        icon: 'tabler:camera-search',
      },
      {
        title: 'HPC and Quantum Research',
        description:
          'Research background includes supercomputing, quantum many-body theory, and computational physics.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Project Management',
        description:
          'Leads R&D projects, technical planning, partner coordination, and delivery management.',
        icon: 'tabler:briefcase',
      },
    ]}
  />

  <Content
    isReversed
    tagline="Current Work"
    title="Applied AI and Research Analysis"
    subtitle="MetaIntelligence works on AI systems for manufacturing, information analysis, and reporting workflows."
    items={[
      {
        title: 'MetaInsight MFG',
        description:
          'Production-data diagnosis and automated report generation, scheduled from June 2026.',
      },
      {
        title: 'MVI DefectSense',
        description:
          'Fine-defect detection using unsupervised normality learning, with VLM-based classification support.',
      },
      {
        title: 'NRF Information Analysis',
        description:
          'Principal investigator for overseas R&D investment analysis and NRF technology-trend research projects.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Research background, practical delivery
      </h3>
      The work starts with the problem structure, then defines the data flow, model role, evaluation criteria, and
      reporting process.
    </Fragment>

    <Fragment slot="image">
      <div class="rounded-lg border border-black/10 bg-white p-8 shadow-lg dark:border-white/10 dark:bg-slate-900">
        <div class="mx-auto max-w-sm [&>svg]:h-auto [&>svg]:w-full" set:html={metaLogoRaw} />
        <p class="mt-6 text-center text-sm font-medium text-muted dark:text-slate-400">
          MetaIntelligence Inc.
        </p>
      </div>
    </Fragment>
  </Content>
</Layout>
