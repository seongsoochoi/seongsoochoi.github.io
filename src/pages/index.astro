---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import metaLogoRaw from '~/assets/images/logo_metaintelligence.svg?raw';

const metadata = {
  title: 'Seongsoo Choi | Integrated AI Solution Architect',
  ignoreTitleTemplate: true,
  description:
    'Seongsoo Choi is CEO of MetaIntelligence and an Integrated AI Solution Architect with a Ph.D. in Physics.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Integrated AI Solution Architect"
    actions={[
      { variant: 'primary', text: 'View Resume', href: '/resume', icon: 'tabler:file-text' },
      { text: 'Contact', href: 'mailto:choi@metaintelligence.co.kr', icon: 'tabler:mail' },
    ]}
  >
    <Fragment slot="title">
      <span class="text-gray-900 dark:text-gray-200">Seongsoo Choi</span>
      <br />
      <span class="text-2xl font-light tracking-wide text-gray-600 dark:text-gray-400">
        CEO, MetaIntelligence
      </span>
    </Fragment>

    <Fragment slot="subtitle">
      Ph.D. physicist building physics-informed AI systems across natural language, vision, high-performance
      computing, and R&amp;D strategy.
    </Fragment>
  </Hero>

  <Stats
    title="Profile at a Glance"
    stats={[
      { title: 'Founded MetaIntelligence', amount: '2021' },
      { title: 'No. 10-2573563', amount: 'AI Patent' },
      { title: 'NRF Projects Led', amount: '7' },
      { title: 'Physics Ph.D.', amount: 'POSTECH' },
    ]}
  />

  <Features
    id="competencies"
    tagline="Core Competencies"
    title="Physics-Informed AI Leadership"
    subtitle="A first-principles approach to AI architecture, manufacturing intelligence, and research commercialization."
    items={[
      {
        title: 'Physics-Informed AI',
        description:
          'Designs AI models and analytical systems from theoretical physics, mathematical structure, and first-principles reasoning.',
        icon: 'tabler:atom',
      },
      {
        title: 'Integrated AI Architecture',
        description:
          'Architects end-to-end solutions that combine NLP, vision AI, optimization, and domain-specific workflows.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'First-Principles NLP',
        description:
          'Developed a patented natural-language data analysis system based on partitioning, digital trees, parameter optimization, and invariant bases.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Manufacturing Vision AI',
        description:
          'Plans anomaly detection and VLM-assisted defect classification systems for high-speed industrial inspection.',
        icon: 'tabler:camera-search',
      },
      {
        title: 'HPC and Quantum Research',
        description:
          'Experienced in large-scale supercomputing, quantum many-body theory, mathematical physics, and computational physics.',
        icon: 'tabler:cpu',
      },
      {
        title: 'R&D Management',
        description:
          'Leads government R&D programs, patent-based commercialization, corporate research operations, and multi-partner project delivery.',
        icon: 'tabler:briefcase',
      },
    ]}
  />

  <Content
    isReversed
    tagline="Current Work"
    title="Building Integrated AI Systems for Real-World Decisions"
    subtitle="MetaIntelligence focuses on applied AI that connects data, diagnosis, reporting, and actionable industrial insight."
    items={[
      {
        title: 'MetaInsight MFG',
        description:
          'Agentic AI for production-data root-cause diagnosis and automated report generation, scheduled from June 2026.',
      },
      {
        title: 'MVI DefectSense',
        description:
          'Unsupervised normality learning for fine-defect detection, paired with VLM-based defect classification and explanation.',
      },
      {
        title: 'NRF Information Analysis',
        description:
          'Principal investigator for overseas R&D investment analysis and multiple NRF technology-trend research projects.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        From mathematical structure to deployed AI
      </h3>
      The work connects theoretical modeling with business execution: define the structure, build the architecture,
      validate the method, and translate it into an AI solution that can be operated by real teams.
    </Fragment>

    <Fragment slot="image">
      <div class="rounded-lg border border-black/10 bg-white p-8 shadow-lg dark:border-white/10 dark:bg-slate-900">
        <div class="mx-auto max-w-sm [&>svg]:h-auto [&>svg]:w-full" set:html={metaLogoRaw} />
        <p class="mt-6 text-center text-sm font-medium text-muted dark:text-slate-400">
          MetaIntelligence Inc.
        </p>
      </div>
    </Fragment>
  </Content>
</Layout>
