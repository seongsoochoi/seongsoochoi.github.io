---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import samsungLogoBlack from '~/assets/images/logo_samsung_black.png';
import samsungLogoWhite from '~/assets/images/logo_samsung_white.png';
import metaLogoRaw from '~/assets/images/logo_metaintelligence.svg?raw';
import vvBreathFocusingDark from '~/assets/multimedia/vanillavibes/vv_breath_focusing_dark.mp4';
import vvBreathFocusingLight from '~/assets/multimedia/vanillavibes/vv_breath_focusing_light.mp4';
import vvScanRevealDark from '~/assets/multimedia/vanillavibes/vv_scan_reveal_dark.mp4';
import vvScanRevealLight from '~/assets/multimedia/vanillavibes/vv_scan_reveal_light.mp4';
const baseUrl = import.meta.env.BASE_URL ?? '/';
const crossBridgePreviewSrc = `${baseUrl}assets/projects/cross-the-bridge/bridge.jpg`;
const smartVoicePreviewSrc = `${baseUrl}assets/projects/smart-voice/settings.jpg`;
const friendlyFarmFarmingSrc = `${baseUrl}assets/projects/friendly-farm/farming.jpg`;
const friendlyFarmDefenseSrc = `${baseUrl}assets/projects/friendly-farm/defense.jpg`;
const familyStoryPreviewSrc = `${baseUrl}assets/projects/family-story/family-story.jpg`;

const metadata = {
  title: 'Resume - Woohyun Kim',
};

const vanillaVibesVideos = [
  { label: 'vv_breath_focusing_light.mp4', src: vvBreathFocusingLight },
  { label: 'vv_breath_focusing_dark.mp4', src: vvBreathFocusingDark },
  { label: 'vv_scan_reveal_light.mp4', src: vvScanRevealLight },
  { label: 'vv_scan_reveal_dark.mp4', src: vvScanRevealDark },
];

const wonderlandVideos = [
  { label: 'https://www.youtube.com/shorts/_sbea9T3yzc', src: 'https://www.youtube.com/embed/_sbea9T3yzc' },
  { label: 'https://www.youtube.com/shorts/ofM3ofy1fek', src: 'https://www.youtube.com/embed/ofM3ofy1fek' },
  { label: 'https://www.youtube.com/shorts/mwvoi2LDb9I', src: 'https://www.youtube.com/embed/mwvoi2LDb9I' },
  { label: 'https://www.youtube.com/shorts/yu2Zy00WKEA', src: 'https://www.youtube.com/embed/yu2Zy00WKEA' },
  { label: 'https://www.youtube.com/shorts/H25LeNEQTl8', src: 'https://www.youtube.com/embed/H25LeNEQTl8' },
];

---

<Layout metadata={metadata}>
  <div class="resume-content">
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Curriculum Vitae"
  >
    <Fragment slot="title">
      Resume
    </Fragment>

    <Fragment slot="subtitle">
      Executive Director & Senior Software Engineer with over 10 years of experience in <br class="hidden md:inline" />
      <span class="font-semibold">3D Graphics</span> and <span class="font-semibold">Generative AI</span>.
    </Fragment>
  </Hero>

  <!-- Company Logos ******************* -->

  <section class="py-4 md:py-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="flex flex-wrap justify-center items-end gap-8 sm:gap-12">
        <div class="flex flex-col items-center gap-2">
          <a
            href="https://www.samsung.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="block"
            aria-label="Samsung Electronics logo"
          >
            <div class="h-12 sm:h-14 w-40 sm:w-44 flex items-center justify-center">
              <img
                src={samsungLogoBlack.src}
                alt="Samsung Electronics"
                class="h-full w-auto object-contain block dark:hidden"
                loading="lazy"
                decoding="async"
              />
              <img
                src={samsungLogoWhite.src}
                alt="Samsung Electronics"
                class="h-full w-auto object-contain hidden dark:block"
                loading="lazy"
                decoding="async"
              />
            </div>
          </a>
          <span class="text-xs text-muted">2014 - 2025</span>
        </div>

        <div class="flex flex-col items-center gap-2">
          <a
            href="https://metaintelligence.github.io/"
            target="_blank"
            rel="noopener noreferrer"
            class="block"
            aria-label="MetaIntelligence logo"
          >
            <div class="h-12 sm:h-14 w-16 sm:w-20 flex items-center justify-center">
              <span class="sr-only">MetaIntelligence</span>
              <div class="meta-logo w-16 sm:w-20 [&>svg]:w-full [&>svg]:h-auto" set:html={metaLogoRaw} />
            </div>
          </a>
          <span class="text-xs text-muted">2025 - Present</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Widget ****************** -->

  <Steps
    id="experience"
    title="Work Experience"
    subtitle="Samsung Electronics entries include concurrent roles; overlapping dates are intentional."
    items={[
      {
        title: 'Executive Director <br /> <span class="font-normal">MetaIntelligence</span> <br /> <span class="text-sm font-normal">2025 - Present</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li>Led <a class="resume-link" href="https://metaintelligence.github.io/solutions/mvi" target="_blank" rel="noopener noreferrer">MVI (Meta Vision AI)</a>, a manufacturing defect detection product; full-stack delivery using GAN and Stable Diffusion models, with shading-aware vision detection.</li>
             <li>Led and built <a class="resume-link" href="https://metaintelligence.github.io/namespring-web/" target="_blank" rel="noopener noreferrer">Namespring</a>, a naming recommendation service, delivering both backend and frontend in a React + Vite stack.</li>
           </ul>`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Software Engineer (Wonderland & AI Effects) <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">2023 - 2025 (Primary role)</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li><button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="wonderland-modal" aria-haspopup="dialog" aria-controls="wonderland-modal">Wonderland</button>: Served as a core developer for the "Wallpaper Transition Effects" section of 'Wonderland' (Good Lock).</li>
             <li><button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="vanillavibes-modal" aria-haspopup="dialog" aria-controls="vanillavibes-modal">VanillaVibes</button>: Built a shared RenderEffect-based AI visual effects rendering library for showcasing AI features across Galaxy phones, and drove its official integration starting with One UI 7.0; it has continued to evolve in active production ever since.</li>
             <li>Internal Graphic Libs: Optimized internal graphics library components, including Transparent Video Player and Skottie View, to improve rendering performance and runtime stability.</li>
           </ul>`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Platform Software Engineer (Watch Face Studio) <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">2020 - 2025 (Concurrent role)</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li>Created <a class="resume-link" href="https://developer.android.com/training/wearables/wff" target="_blank" rel="noopener">WFF (Android Watch Face Format)</a>, an XML-based format defined by the <a class="resume-link" href="https://github.com/google/watchface/commit/bbc2def58c94b18c4deec12d079b2792c2a33fef" target="_blank" rel="noopener">XSD I authored</a> (publicly mirrored from my Samsung work to avoid exposing internal Git history), and built a validator for compatibility and quality checks.</li>
             <li>Participated in developing the <a class="resume-link" href="https://developer.samsung.com/watch-face-studio/overview.html" target="_blank" rel="noopener">Watch Face Studio</a> preview rendering pipeline.</li>
             <li>Participated in developing the WFF loader as the Wear OS watch face runtime; the Samsung-built runtime was later adopted into the Android platform and integrated into AOSP as an official watch face loader module.</li>
           </ul>`,
        icon: 'tabler:briefcase',
      },
      {
        title: 'Android Graphics Engineer <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">2019 - 2020</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li>Implemented 'Runtime Gradient Blur' (Patent Grade A) and multi-window blur effects.</li>
             <li>Proved window‑independent Android view blur via PoC and report; the methodology was later adopted in Samsung phones by the owning team.</li>
             <li>Implemented <a class="resume-link" href="https://youtu.be/ZGL_8u3thSU?t=14" target="_blank" rel="noopener">Weather‑Raindrop</a> rendering for a Samsung in‑house watch face, based on reverse‑engineering the open‑source <a class="resume-link" href="https://tympanus.net/Development/RainEffect/" target="_blank" rel="noopener">RainEffect</a>.</li>
           </ul>`,
        icon: 'tabler:brand-android',
      },
      {
        title: 'Tizen Graphics Engineer <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">2018 - 2019</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li>Implemented <a class="resume-link" href="https://www.youtube.com/watch?v=B_CbUWJJ4cw" target="_blank" rel="noopener">Activity Sparkles</a> rendering for a Samsung in‑house watch face.</li>
             <li>Participated in the internal experimental project WatchFactory, a DALi-based 3D watch face tool for Tizen-based Samsung watches; it later evolved into Watch Face Studio.</li>
           </ul>`,
        icon: 'tabler:device-watch',
      },
      {
        title: 'Mobile GPU Driver Engineer <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">2016 - 2018</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li>Engineered ARM Mali GPU drivers for Samsung mobile products.</li>
             <li>Focused on driver stability, Khronos compliance, and performance tuning.</li>
             <li>Debugged complex GPU driver issues using low-level profiling tools.</li>
           </ul>`,
        icon: 'tabler:cpu',
      },
      {
        title: 'Samsung Software Membership <br /> <span class="text-sm font-normal">2014 - 2015</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li>Regular member, 24-1st.</li>
             <li>Education Team Leader (2014 - 2015).</li>
             <li>Seminar: Vector, Matrix and Quaternion for 3D Programming — <button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="seminar-3d-math-modal" aria-haspopup="dialog" aria-controls="seminar-3d-math-modal">Preview</button>.</li>
             <li>Seminar: OpenMP and MPI for Beginners — <button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="seminar-openmp-modal" aria-haspopup="dialog" aria-controls="seminar-openmp-modal">Preview</button>.</li>
             <li><button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="crossbridge-modal" aria-haspopup="dialog" aria-controls="crossbridge-modal">Cross the Bridge</button>: 3D game engine + bridge simulation; project lead and physics engine (RPEngine) developer.</li>
             <li><button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="smartvoice-modal" aria-haspopup="dialog" aria-controls="smartvoice-modal">SmartVoice</button>: Voice‑based Android system service using third‑party collective intelligence, with related AOSP platform changes.</li>
           </ul>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Education Widget ****************** -->

  <Steps
    id="education"
    title="Education"
    items={[
      {
        title: 'Bachelor of Science in Software Engineering & Applied Mathematics <br /> <span class="font-normal">Kumoh National Institute of Technology</span> <br /> <span class="text-sm font-normal">2008 - 2015</span>',
        icon: 'tabler:school',
      },
      {
        title: 'Student Projects <br /> <span class="text-sm font-normal">Kumoh National Institute of Technology</span>',
        description:
          `<ul class="list-disc pl-5 space-y-1">
             <li><button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="friendly-farm-modal" aria-haspopup="dialog" aria-controls="friendly-farm-modal">Friendly Farm</button>: Social network game (SNG) with farming simulation and defense gameplay; project lead.</li>
             <li><button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="family-story-modal" aria-haspopup="dialog" aria-controls="family-story-modal">Family Story</button>: Family-focused SNS application built as an Android hybrid web app; project lead.</li>
           </ul>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Skills Widget ****************** -->

  <Features3
    title="Technical Skills"
    subtitle="A comprehensive overview of my technical capabilities."
    columns={3}
    classes={{ items: { container: 'skills-grid mt-10 max-w-5xl', panel: 'max-w-none w-full' } }}
    items={[
      {
        title: 'Languages',
        description: 'C++, Java, Kotlin, Python, C#, GLSL, TypeScript, HTML',
        icon: 'tabler:code',
      },
      {
        title: 'Graphics & GPU',
        description: 'OpenGL ES, Unity3D, Renderdoc, Mali Graphics Debugger',
        icon: 'tabler:cube',
      },
      {
        title: 'AI',
        description: 'Deep Learning, Generative AI, PyTorch, TensorFlow',
        icon: 'tabler:brain',
      },
      {
        title: 'Frameworks & Platforms',
        description: 'Android Framework, Android Wear, React, Electron, Vite',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Tools',
        description: 'Android Studio, Visual Studio Code, IntelliJ, Blender, Git, CI/CD pipelines',
        icon: 'tabler:tools',
      },
    ]}
  />

  <!-- Journals & Awards Widget ****************** -->

  <Content
    title="Journals & Awards"
    items={[
      {
        title: 'Journal Publication (2016)',
        description:
          'Seongsoo Choi, <strong>Woohyun Kim</strong>, and Jongho Kim, “Compression of Hamiltonian matrix: Application to spin-1/2 Heisenberg square lattice,” AIP Advances (2016). <a class="resume-link" href="https://aip.scitation.org/doi/pdf/10.1063/1.4963834" target="_blank" rel="noopener">PDF</a>.',
      },
      {
        title: 'K-Hackathon 3 (2015): Grand Award (Minister Award)',
        description: 'Received the highest honor for "Team Globell" (Web-based global free internet phone service).',
      },
      {
        title: 'KIT Engineering Fair (2014): Silver Award',
        description: 'Recognized for "Team Friendly Farm" (Farming simulation SNG).',
      },
      {
        title: 'HPCSS@UNIST (2014): Outstanding Contribution Award',
        description: 'Awarded for "Team UIRI" (Simulation of double-slit experiment using Supercomputing).',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1562564055-71e051d33c19?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Awards Image',
    }}
  >
  </Content>

  <!-- VanillaVibes Modal ****************** -->

  <div id="vanillavibes-modal" class="media-modal fixed inset-0 z-[9999] hidden" aria-hidden="true" data-modal>
    <div class="media-backdrop absolute inset-0 z-0 bg-black/40 backdrop-blur-sm" data-modal-close></div>
    <div class="relative mx-auto my-8 max-w-5xl px-4 sm:px-6">
      <div
        class="modal-panel relative z-10 rounded-xl bg-white dark:bg-slate-900 shadow-xl border border-black/10 dark:border-white/10 pointer-events-auto"
        role="dialog"
        aria-modal="true"
        aria-label="VanillaVibes videos"
      >
        <div class="flex items-center justify-between px-4 sm:px-6 py-3 border-b border-black/10 dark:border-white/10">
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-slate-100">VanillaVibes</div>
            <div class="text-xs text-gray-500 dark:text-slate-400 hidden"></div>
          </div>
          <button
            type="button"
            class="text-sm text-gray-500 hover:text-gray-800 dark:text-slate-400 dark:hover:text-slate-200"
            data-modal-close
          >
            Close
          </button>
        </div>
        <div class="grid gap-4 sm:gap-6 p-4 sm:p-6 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
          <div class="media-player-card rounded-lg bg-black/5 dark:bg-black/30 p-2 sm:p-3">
            <video
              id="vanillavibes-player"
              class="media-player w-full max-w-full rounded-md bg-black object-contain"
              controls
              preload="metadata"
            ></video>
          </div>
          <div>
            <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-2">Clips</div>
            <ul class="space-y-2">
              {
                vanillaVibesVideos.map((video, index) => (
                  <li>
                    <button
                      type="button"
                      class={`media-item w-full text-left rounded-md px-3 py-2 text-sm border border-black/10 dark:border-white/10 ${
                        index === 0 ? 'is-active' : ''
                      }`}
                      data-vv-src={video.src}
                    >
                      {video.label}
                    </button>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wonderland Modal ****************** -->

  <div id="wonderland-modal" class="media-modal fixed inset-0 z-[9999] hidden" aria-hidden="true" data-modal>
    <div class="media-backdrop absolute inset-0 z-0 bg-black/40 backdrop-blur-sm" data-modal-close></div>
    <div class="relative mx-auto my-8 max-w-5xl px-4 sm:px-6">
      <div
        class="modal-panel relative z-10 rounded-xl bg-white dark:bg-slate-900 shadow-xl border border-black/10 dark:border-white/10 pointer-events-auto"
        role="dialog"
        aria-modal="true"
        aria-label="Wonderland videos"
      >
        <div class="flex items-center justify-between px-4 sm:px-6 py-3 border-b border-black/10 dark:border-white/10">
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-slate-100">Wonderland</div>
            <div class="text-xs text-gray-500 dark:text-slate-400">
              To see more videos, search for Samsung Galaxy Wonderland on YouTube.
            </div>
          </div>
          <button
            type="button"
            class="text-sm text-gray-500 hover:text-gray-800 dark:text-slate-400 dark:hover:text-slate-200"
            data-modal-close
          >
            Close
          </button>
        </div>
        <div class="grid gap-4 sm:gap-6 p-4 sm:p-6 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
          <div class="media-player-card rounded-lg bg-black/5 dark:bg-black/30 p-2 sm:p-3">
            <iframe
              id="wonderland-player"
              class="media-player w-full max-w-full rounded-md bg-black"
              src=""
              title="Wonderland YouTube player"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
          <div>
            <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-2">Clips</div>
            <ul class="space-y-2">
              {
                wonderlandVideos.map((video, index) => (
                  <li>
                    <button
                      type="button"
                      class={`media-item w-full text-left rounded-md px-3 py-2 text-sm border border-black/10 dark:border-white/10 break-all ${
                        index === 0 ? 'is-active' : ''
                      }`}
                      data-ww-src={video.src}
                    >
                      {video.label}
                    </button>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Cross the Bridge Modal ****************** -->

  <div id="crossbridge-modal" class="media-modal fixed inset-0 z-[9999] hidden" aria-hidden="true" data-modal>
    <div class="media-backdrop absolute inset-0 z-0 bg-black/40 backdrop-blur-sm" data-modal-close></div>
    <div class="relative mx-auto my-8 max-w-5xl px-4 sm:px-6">
      <div
        class="modal-panel relative z-10 rounded-xl bg-white dark:bg-slate-900 shadow-xl border border-black/10 dark:border-white/10 pointer-events-auto"
        role="dialog"
        aria-modal="true"
        aria-label="Cross the Bridge"
      >
        <div class="flex items-center justify-between px-4 sm:px-6 py-3 border-b border-black/10 dark:border-white/10">
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-slate-100">Cross the Bridge</div>
            <div class="text-xs text-gray-500 dark:text-slate-400">
              3D game engine + bridge simulation; project lead and physics engine (RPEngine) developer.
            </div>
          </div>
          <button
            type="button"
            class="text-sm text-gray-500 hover:text-gray-800 dark:text-slate-400 dark:hover:text-slate-200"
            data-modal-close
          >
            Close
          </button>
        </div>
        <div class="grid gap-4 sm:gap-6 p-4 sm:p-6 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
          <div class="media-player-card rounded-lg bg-black/5 dark:bg-black/30 p-2 sm:p-3">
            <iframe
              id="crossbridge-player"
              class="media-player w-full max-w-full rounded-md bg-black"
              src=""
              title="Cross the Bridge YouTube player"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
            <img
              id="crossbridge-thumb"
              src={crossBridgePreviewSrc}
              alt="Cross the Bridge preview"
              class="media-thumb hidden w-full rounded-md object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="space-y-3">
            <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-slate-400">Resources</div>
            <button
              type="button"
              class="media-item w-full text-left rounded-md px-3 py-2 text-sm border border-black/10 dark:border-white/10 inline-block"
              data-cb-show="video"
            >
              YouTube
            </button>
            <button
              type="button"
              class="media-item w-full text-left rounded-md px-3 py-2 text-sm border border-black/10 dark:border-white/10 inline-block"
              data-cb-show="thumb"
            >
              Thumbnail
            </button>
            <a
              class="media-item w-full text-left rounded-md px-3 py-2 text-sm border border-black/10 dark:border-white/10 inline-block"
              href="https://github.com/artrointel/RPEngine"
              target="_blank"
              rel="noopener"
            >
              RPEngine
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SmartVoice Modal ****************** -->

  <div id="smartvoice-modal" class="media-modal fixed inset-0 z-[9999] hidden" aria-hidden="true" data-modal>
    <div class="media-backdrop absolute inset-0 z-0 bg-black/40 backdrop-blur-sm" data-modal-close></div>
    <div class="relative mx-auto my-8 max-w-5xl px-4 sm:px-6">
      <div
        class="modal-panel relative z-10 rounded-xl bg-white dark:bg-slate-900 shadow-xl border border-black/10 dark:border-white/10 pointer-events-auto"
        role="dialog"
        aria-modal="true"
        aria-label="SmartVoice"
      >
        <div class="flex items-center justify-between px-4 sm:px-6 py-3 border-b border-black/10 dark:border-white/10">
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-slate-100">SmartVoice</div>
            <div class="text-xs text-gray-500 dark:text-slate-400">
              Voice‑based Android system service using third‑party collective intelligence, with related AOSP platform changes.
            </div>
          </div>
          <button
            type="button"
            class="text-sm text-gray-500 hover:text-gray-800 dark:text-slate-400 dark:hover:text-slate-200"
            data-modal-close
          >
            Close
          </button>
        </div>
