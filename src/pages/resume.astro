<script is:inline>
  const syncMetaLogoTheme = () => {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('.meta-logo svg').forEach((svg) => {
      svg.classList.toggle('dark', isDark);
      svg.classList.toggle('light', !isDark);
    });
  };

  syncMetaLogoTheme();

  const observer = new MutationObserver(syncMetaLogoTheme);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  const initVanillaVibesModal = () => {
    const modal = document.getElementById('vanillavibes-modal');
    if (!modal || modal.dataset.vvBound === 'true') return;
    const player = modal.querySelector('#vanillavibes-player');
    if (!player) return;

    modal.dataset.vvBound = 'true';

    const getButtons = () => Array.from(modal.querySelectorAll('[data-vv-src]'));

    const setActiveVideo = (button, shouldPlay = false) => {
      if (!button || !player) return;
      const buttons = getButtons();
      buttons.forEach((btn) => btn.classList.remove('is-active'));
      button.classList.add('is-active');
      const src = button.getAttribute('data-vv-src');
      if (src) {
        player.src = src;
        player.load();
        if (shouldPlay) {
          player.play().catch(() => {});
        }
      }
    };

    const resetPlayer = () => {
      if (!player) return;
      player.pause();
      player.removeAttribute('src');
      player.load();
    };

    modal.addEventListener('modal:open', () => {
      const buttons = getButtons();
      setActiveVideo(buttons[0], false);
    });
    modal.addEventListener('modal:close', resetPlayer);

    modal.addEventListener('click', (event) => {
      const button = event.target.closest('[data-vv-src]');
      if (button) {
        setActiveVideo(button, true);
      }
    });
  };

  initVanillaVibesModal();
  document.addEventListener('astro:after-swap', initVanillaVibesModal);

  const initWonderlandModal = () => {
    const modal = document.getElementById('wonderland-modal');
    if (!modal || modal.dataset.wwBound === 'true') return;
    const player = modal.querySelector('#wonderland-player');
    if (!player) return;

    modal.dataset.wwBound = 'true';

    const getButtons = () => Array.from(modal.querySelectorAll('[data-ww-src]'));

    const setActiveVideo = (button) => {
      if (!button || !player) return;
      const buttons = getButtons();
      buttons.forEach((btn) => btn.classList.remove('is-active'));
      button.classList.add('is-active');
      const src = button.getAttribute('data-ww-src');
      if (src) {
        player.setAttribute('src', `${src}?rel=0&modestbranding=1`);
      }
    };

    const resetPlayer = () => {
      if (!player) return;
      player.setAttribute('src', '');
    };

    modal.addEventListener('modal:open', () => {
      const buttons = getButtons();
      setActiveVideo(buttons[0]);
    });
    modal.addEventListener('modal:close', resetPlayer);

    modal.addEventListener('click', (event) => {
      const button = event.target.closest('[data-ww-src]');
      if (button) {
        setActiveVideo(button);
      }
    });
  };

  initWonderlandModal();
  document.addEventListener('astro:after-swap', initWonderlandModal);

  const initSimpleIframeModal = (modalId, embedSrc) => {
    const modal = document.getElementById(modalId);
    if (!modal || modal.dataset.simpleBound === 'true') return;
    const player = modal.querySelector('iframe');
    if (!player) return;

    modal.dataset.simpleBound = 'true';

    const resetPlayer = () => {
      player.setAttribute('src', '');
    };

    modal.addEventListener('modal:open', () => {
      player.setAttribute('src', embedSrc);
    });
    modal.addEventListener('modal:close', resetPlayer);
  };

  const initCrossBridgeModal = () => {
    const modal = document.getElementById('crossbridge-modal');
    if (!modal || modal.dataset.cbBound === 'true') return;
    const player = modal.querySelector('#crossbridge-player');
    const thumb = modal.querySelector('#crossbridge-thumb');
    if (!player || !thumb) return;

    modal.dataset.cbBound = 'true';

    const showVideo = () => {
      thumb.classList.add('hidden');
      player.classList.remove('hidden');
      player.setAttribute(
        'src',
        'https://www.youtube.com/embed/j9WeBjJaUlE?list=PLFvdltGhnoAOEi8856S_SpO5De_5REK_o&rel=0&modestbranding=1'
      );
    };

    const showThumb = () => {
      player.setAttribute('src', '');
      player.classList.add('hidden');
      thumb.classList.remove('hidden');
    };

    modal.addEventListener('modal:open', showVideo);
    modal.addEventListener('modal:close', showThumb);

    modal.addEventListener('click', (event) => {
      if (event.target.closest('[data-cb-show="video"]')) {
        showVideo();
      } else if (event.target.closest('[data-cb-show="thumb"]')) {
        showThumb();
      }
    });
  };

  const initSmartVoiceModal = () => {
    const modal = document.getElementById('smartvoice-modal');
    if (!modal || modal.dataset.svBound === 'true') return;
    const player = modal.querySelector('#smartvoice-player');
    const thumb = modal.querySelector('#smartvoice-thumb');
    if (!player || !thumb) return;

    modal.dataset.svBound = 'true';

    const showVideo = () => {
      thumb.classList.add('hidden');
      player.classList.remove('hidden');
      player.setAttribute(
        'src',
        'https://www.youtube.com/embed/videoseries?list=PLFvdltGhnoANUmPkSl9IVSECUSKcswDoK&rel=0&modestbranding=1'
      );
    };

    const showThumb = () => {
      player.setAttribute('src', '');
      player.classList.add('hidden');
      thumb.classList.remove('hidden');
    };

    modal.addEventListener('modal:open', showVideo);
    modal.addEventListener('modal:close', showThumb);

    modal.addEventListener('click', (event) => {
      if (event.target.closest('[data-sv-show="video"]')) {
        showVideo();
      } else if (event.target.closest('[data-sv-show="thumb"]')) {
        showThumb();
      }
    });
  };

  const initFriendlyFarmModal = () => {
    const modal = document.getElementById('friendly-farm-modal');
    if (!modal || modal.dataset.ffBound === 'true') return;
    const player = modal.querySelector('#friendly-farm-player');
    const farmingThumb = modal.querySelector('#friendly-farm-thumb-farming');
    const defenseThumb = modal.querySelector('#friendly-farm-thumb-defense');
    if (!player || !farmingThumb || !defenseThumb) return;

    modal.dataset.ffBound = 'true';

    const hideThumbs = () => {
      farmingThumb.classList.add('hidden');
      defenseThumb.classList.add('hidden');
    };

    const showVideo = () => {
      hideThumbs();
      player.classList.remove('hidden');
      player.setAttribute(
        'src',
        'https://www.youtube.com/embed/8CI9qfpottU?list=PLFvdltGhnoAPDOS2YjjSNd1FlrL-JpJZt&rel=0&modestbranding=1'
      );
    };

    const showThumb = (variant) => {
      player.setAttribute('src', '');
      player.classList.add('hidden');
      hideThumbs();
      if (variant === 'defense') {
        defenseThumb.classList.remove('hidden');
      } else {
        farmingThumb.classList.remove('hidden');
      }
    };

    modal.addEventListener('modal:open', showVideo);
    modal.addEventListener('modal:close', () => showThumb('farming'));

    modal.addEventListener('click', (event) => {
      const button = event.target.closest('[data-ff-show]');
      if (!button) return;
      const target = button.getAttribute('data-ff-show');
      if (target === 'video') {
        showVideo();
      } else {
        showThumb(target);
      }
    });
  };

  initCrossBridgeModal();
  initSmartVoiceModal();
  initFriendlyFarmModal();
  initSimpleIframeModal(
    'seminar-3d-math-modal',
    'https://www.slideshare.net/slideshow/embed_code/key/j8r1JUnNZet8E0'
  );
  initSimpleIframeModal(
    'seminar-openmp-modal',
    'https://www.slideshare.net/slideshow/embed_code/key/b8E8s3PsQjwKqr'
  );

  document.addEventListener('astro:after-swap', () => {
    initCrossBridgeModal();
    initSmartVoiceModal();
    initFriendlyFarmModal();
    initSimpleIframeModal(
      'seminar-3d-math-modal',
      'https://www.slideshare.net/slideshow/embed_code/key/j8r1JUnNZet8E0'
    );
    initSimpleIframeModal(
      'seminar-openmp-modal',
      'https://www.slideshare.net/slideshow/embed_code/key/b8E8s3PsQjwKqr'
    );
  });
</script>

