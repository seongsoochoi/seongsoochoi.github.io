---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import metaLogoRaw from '~/assets/images/logo_metaintelligence.svg?raw';

const metadata = {
  title: 'Resume - Seongsoo Choi',
  description:
    'Resume of Seongsoo Choi, CEO of MetaIntelligence, AI systems architect, and Ph.D. in Physics.',
};

const careerItems = [
  {
    title:
      'CEO / President <br /> <span class="font-normal">MetaIntelligence Inc.</span> <br /> <span class="text-sm font-normal">2021.12 - Present</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Founded MetaIntelligence and leads strategy, research operations, and R&amp;D projects.</li>
        <li>Works on AI systems across NLP, vision, manufacturing data, and reporting workflows.</li>
        <li>Oversees patent-related work and government R&amp;D projects.</li>
      </ul>`,
    icon: 'tabler:building',
  },
  {
    title:
      'Principal Researcher / AI Master <br /> <span class="font-normal">F1Soft Co., Ltd.</span> <br /> <span class="text-sm font-normal">2021.10 - 2022.01</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Worked on supercomputing, rule-based and AI-based natural-language processing, and machine vision.</li>
      </ul>`,
    icon: 'tabler:brain',
  },
  {
    title:
      'Staff Software Engineer, Advanced Technology Research <br /> <span class="font-normal">Samsung Display Co., Ltd.</span> <br /> <span class="text-sm font-normal">2017.09 - 2020.03</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Developed AI and computer-vision automation for defect inspection across cell, module, and FAB environments.</li>
        <li>Built internal advanced software for manufacturing-inspection workflows.</li>
      </ul>`,
    icon: 'tabler:camera-search',
  },
  {
    title:
      'Postdoctoral Researcher / KISTI Project Principal Investigator <br /> <span class="font-normal">UNIST</span> <br /> <span class="text-sm font-normal">2016.02 - 2017.08</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Led machine-learning research based on large-scale supercomputing resources.</li>
      </ul>`,
    icon: 'tabler:cpu',
  },
  {
    title:
      'Invited Participant, Fully Funded Summer School <br /> <span class="font-normal">UCLA</span> <br /> <span class="text-sm font-normal">2014.07 - 2014.08</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Studied electronic-structure theory for materials and biomolecular systems.</li>
      </ul>`,
    icon: 'tabler:school',
  },
  {
    title:
      'Researcher <br /> <span class="font-normal">WCU POSTECH</span> <br /> <span class="text-sm font-normal">2011.09 - 2012.12</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Researched quantum field theory and strongly correlated electronic systems under Prof. E. J. Baerends.</li>
      </ul>`,
    icon: 'tabler:atom',
  },
  {
    title:
      'Global Ph.D. Fellow <br /> <span class="font-normal">National Research Foundation of Korea / POSTECH</span> <br /> <span class="text-sm font-normal">2011.03 - 2016.02</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Completed doctoral research under Prof. Kwang S. Kim, now Distinguished Professor at UNIST.</li>
      </ul>`,
    icon: 'tabler:award',
  },
];

const educationItems = [
  {
    title:
      'Ph.D. in Physics <br /> <span class="font-normal">POSTECH</span> <br /> <span class="text-sm font-normal">2011.03 - 2016.02</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Major fields: mathematical physics, computational physics, condensed matter physics, and quantum many-body theory.</li>
        <li>Dissertation: three topics in mathematical physics, including irreducible matrix eigenvalue reduction, eigen-graph methods for nearly overlapped states, and primes and roots in the Riemann hypothesis.</li>
      </ul>`,
    icon: 'tabler:school',
  },
  {
    title:
      'B.S., Division of Natural Sciences <br /> <span class="font-normal">Kumoh National Institute of Technology</span> <br /> <span class="text-sm font-normal">2004.03 - 2011.02</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Double major in physics and applied mathematics.</li>
      </ul>`,
    icon: 'tabler:school',
  },
];

const projectItems = [
  {
    title:
      'MetaInsight MFG <br /> <span class="font-normal">AX-LLM Collaboration Project</span> <br /> <span class="text-sm font-normal">Scheduled from 2026.06</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Root-cause diagnosis and automated report generation from production data.</li>
        <li>Role: PM and architect, with 60 percent allocation and NC AI collaboration ownership.</li>
      </ul>`,
    icon: 'tabler:robot',
  },
  {
    title:
      'MVI DefectSense <br /> <span class="font-normal">Manufacturing Vision AI</span> <br /> <span class="text-sm font-normal">Planned 2026</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>High-speed fine-defect detection based on unsupervised normality learning.</li>
        <li>Designed with VLM-based defect classification and explanation.</li>
      </ul>`,
    icon: 'tabler:camera-search',
  },
  {
    title:
      'MicroDIPS - Anomaly Detection and Data Augmentation <br /> <span class="font-normal">Korea Institute of Startup and Entrepreneurship Development</span> <br /> <span class="text-sm font-normal">2025.08 - 2025.12</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Led the full project as PM for the ACIA and Ara consortium.</li>
      </ul>`,
    icon: 'tabler:chart-dots',
  },
  {
    title:
      'Overseas R&D Investment Information Analysis <br /> <span class="font-normal">National Research Foundation of Korea</span> <br /> <span class="text-sm font-normal">2025.06 - 2026.02</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Served as principal investigator for analysis of overseas R&amp;D investment status.</li>
      </ul>`,
    icon: 'tabler:report-analytics',
  },
  {
    title:
      'NRF Research Projects <br /> <span class="font-normal">Four consecutive years of re-orders, seven cumulative projects</span> <br /> <span class="text-sm font-normal">2022.10 - 2026.02</span>',
    description:
      `<ul class="list-disc pl-5 space-y-1">
        <li>Served as principal investigator for repeated NRF research-analysis projects.</li>
      </ul>`,
    icon: 'tabler:files',
  },
];
---

<Layout metadata={metadata}>
  <div class="resume-content">
    <Hero
      tagline="Curriculum Vitae"
      actions={[
        { variant: 'primary', text: 'Email', href: 'mailto:choi@metaintelligence.co.kr', icon: 'tabler:mail' },
        { text: 'About', href: '/about', icon: 'tabler:user' },
      ]}
    >
      <Fragment slot="title">Resume</Fragment>

      <Fragment slot="subtitle">
        Seongsoo Choi is CEO and president of MetaIntelligence, with work across applied AI systems and physics-based
        research.
      </Fragment>
    </Hero>

    <section class="py-4 md:py-6">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <div class="flex flex-col items-center gap-3">
          <div class="h-24 w-36 sm:h-28 sm:w-44 [&>svg]:h-full [&>svg]:w-full" set:html={metaLogoRaw} />
          <div class="text-center">
            <div class="text-sm font-semibold text-gray-900 dark:text-white">MetaIntelligence Inc.</div>
            <div class="text-xs text-muted">Founded December 10, 2021</div>
          </div>
        </div>
      </div>
    </section>

    <Stats
      title="Profile"
      stats={[
        { title: 'Current Role', amount: 'CEO' },
        { title: 'Registered Patent', amount: '1' },
        { title: 'NRF Projects', amount: '7' },
        { title: 'Doctorate', amount: 'PhD' },
      ]}
    />

    <Steps
      id="experience"
      title="Career Experience"
      subtitle="Experience across AI company operations, industrial vision AI, supercomputing, and physics research."
      items={careerItems}
      classes={{ container: 'max-w-3xl' }}
    />

    <Features3
      id="skills"
      title="Core Capabilities"
      subtitle="Technical and management areas from the resume."
      columns={3}
      classes={{ items: { container: 'skills-grid mt-10 max-w-5xl', panel: 'max-w-none w-full' } }}
      items={[
        {
          title: 'Physics-Informed AI',
          description: 'AI design informed by physics and mathematical modeling.',
          icon: 'tabler:atom',
        },
        {
          title: 'Natural Language Analysis',
          description:
            'Mathematical partitioning of natural-language datasets, digital-tree construction, parameter optimization, and invariant-basis derivation.',
          icon: 'tabler:binary-tree',
        },
        {
          title: 'Applied AI Systems',
          description: 'NLP and vision AI workflows for industrial and research applications.',
          icon: 'tabler:sitemap',
        },
        {
          title: 'HPC and Quantum',
          description: 'Large-scale supercomputing operations, quantum many-body theory, and computational physics.',
          icon: 'tabler:cpu',
        },
        {
          title: 'Unsupervised Anomaly Detection',
          description: 'Vision-based normality learning for high-speed defect detection and classification workflows.',
          icon: 'tabler:camera-search',
        },
        {
          title: 'R&D Management',
          description: 'Government R&D projects, technical planning, and partner coordination.',
          icon: 'tabler:briefcase',
        },
      ]}
    />

    <Steps
      id="education"
      title="Education"
      items={educationItems}
      classes={{ container: 'max-w-3xl' }}
    />

    <Steps
      id="projects"
      title="Selected Projects"
      subtitle="Public project summaries from the resume."
      items={projectItems}
      classes={{ container: 'max-w-3xl' }}
    />

    <Content
      title="IP and Publications"
      subtitle="Patent and academic work."
      items={[
        {
          title: 'Korean Patent No. 10-2573563',
          description:
            'Natural-language data analysis system and method. Sole inventor: Seongsoo Choi. Assignee: MetaIntelligence Inc. Filed 2022.11.02 and registered 2023.08.29.',
        },
        {
          title: 'Journal of Mathematical Physics',
          description:
            'Choi, S., Chung, J. W., Kim, K. S., "Relation between primes and nontrivial zeros in the Riemann hypothesis; Legendre polynomials, modified zeta function and Schrodinger equation," Journal of Mathematical Physics 53, 122108 (2012). DOI <a class="resume-link" href="https://doi.org/10.1063/1.4770050" target="_blank" rel="noopener">10.1063/1.4770050</a>.',
        },
        {
          title: 'Doctoral Dissertation',
          description:
            'Three topics in mathematical physics, completed at POSTECH Department of Physics in 2016.',
        },
      ]}
    >
      <Fragment slot="image">
        <div class="rounded-lg border border-black/10 bg-white p-8 shadow-lg dark:border-white/10 dark:bg-slate-900">
          <div class="mx-auto max-w-xs [&>svg]:h-auto [&>svg]:w-full" set:html={metaLogoRaw} />
          <div class="mt-6 text-center">
            <div class="text-sm font-semibold text-gray-900 dark:text-white">Registered IP and Research Output</div>
            <p class="mt-2 text-sm text-muted dark:text-slate-400">
              Registered patent, journal publication, and doctoral dissertation.
            </p>
          </div>
        </div>
      </Fragment>
    </Content>

    <Features3
      title="Awards and Public Activity"
      columns={2}
      items={[
        {
          title: 'KAST Preliminary Leading Scientist',
          description: 'Selected by the Korean Academy of Science and Technology in 2011.',
          icon: 'tabler:award',
        },
        {
          title: 'Global Ph.D. Fellowship',
          description: 'National Research Foundation of Korea fellowship recipient from 2011.03 to 2016.02.',
          icon: 'tabler:school',
        },
        {
          title: 'UCLA Summer School',
          description: 'Fully funded invited participant in 2014 for electronic-structure theory.',
          icon: 'tabler:certificate',
        },
        {
          title: 'Public Research and Review',
          description:
            'Principal investigator for NRF projects, author of MSIT/NRF reports on quantum computing and metaverse technology trends, and chair judge for an AI training-data hackathon.',
          icon: 'tabler:gavel',
        },
      ]}
    />
  </div>
</Layout>

<style>
  @media (min-width: 1024px) {
    .skills-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr)) !important;
    }

    .skills-grid > * {
      grid-column: span 2 / span 2;
    }
  }

  :global(.resume-content .resume-link) {
    color: #2563eb !important;
    font-weight: 600 !important;
  }

  :global(.resume-content .resume-link:hover) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  :global(html.dark) .resume-content .resume-link {
    color: #60a5fa !important;
  }
</style>
