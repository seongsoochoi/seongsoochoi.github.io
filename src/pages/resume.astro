---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import samsungLogoBlack from '~/assets/images/logo_samsung_black.png';
import samsungLogoWhite from '~/assets/images/logo_samsung_white.png';
import metaLogoRaw from '~/assets/images/logo_metaintelligence.svg?raw';
import vvBreathFocusingDark from '~/assets/multimedia/vanillavibes/vv_breath_focusing_dark.mp4';
import vvBreathFocusingLight from '~/assets/multimedia/vanillavibes/vv_breath_focusing_light.mp4';
import vvScanRevealDark from '~/assets/multimedia/vanillavibes/vv_scan_reveal_dark.mp4';
import vvScanRevealLight from '~/assets/multimedia/vanillavibes/vv_scan_reveal_light.mp4';

const metadata = {
  title: 'Resume - Woohyun Kim',
};

const vanillaVibesVideos = [
  { label: 'vv_breath_focusing_light.mp4', src: vvBreathFocusingLight },
  { label: 'vv_breath_focusing_dark.mp4', src: vvBreathFocusingDark },
  { label: 'vv_scan_reveal_light.mp4', src: vvScanRevealLight },
  { label: 'vv_scan_reveal_dark.mp4', src: vvScanRevealDark },
];

---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Curriculum Vitae"
  >
    <Fragment slot="title">
      Resume
    </Fragment>

    <Fragment slot="subtitle">
      Executive Director & Senior Software Engineer with over 10 years of experience in <br class="hidden md:inline" />
      <span class="font-semibold">3D Graphics</span> and <span class="font-semibold">Generative AI</span>.
    </Fragment>
  </Hero>

  <!-- Company Logos ******************* -->

  <section class="py-4 md:py-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="flex flex-wrap justify-center items-end gap-8 sm:gap-12">
        <div class="flex flex-col items-center gap-2">
          <a
            href="https://www.samsung.com/sec/about-us/brand-identity/logo/"
            target="_blank"
            rel="noopener"
            class="block"
            aria-label="Samsung Electronics logo"
          >
            <div class="h-12 sm:h-14 w-40 sm:w-44 flex items-center justify-center">
              <img
                src={samsungLogoBlack.src}
                alt="Samsung Electronics"
                class="h-full w-auto object-contain block dark:hidden"
                loading="lazy"
                decoding="async"
              />
              <img
                src={samsungLogoWhite.src}
                alt="Samsung Electronics"
                class="h-full w-auto object-contain hidden dark:block"
                loading="lazy"
                decoding="async"
              />
            </div>
          </a>
          <span class="text-xs text-muted">2014-2025</span>
        </div>

        <div class="flex flex-col items-center gap-2">
          <div class="h-12 sm:h-14 w-16 sm:w-20 flex items-center justify-center">
            <span class="sr-only">MetaIntelligence</span>
            <div class="meta-logo w-16 sm:w-20 [&>svg]:w-full [&>svg]:h-auto" set:html={metaLogoRaw} />
          </div>
          <span class="text-xs text-muted">2025-Present</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Widget ****************** -->

  <Steps
    id="experience"
    title="Work Experience"
    items={[
      {
        title: 'Executive Director <br /> <span class="font-normal">MetaIntelligence</span> <br /> <span class="text-sm font-normal">2025 - Present</span>',
        description:
          `• Led MVI (Meta Vision AI), a manufacturing defect detection product; full-stack delivery using GAN and Stable Diffusion models, with shading-aware vision detection.<br />
           • Led and built Namespring, a naming recommendation service, delivering both backend and frontend in a React + Vite stack.`,
        icon: 'tabler:briefcase',
      },
      {
        title: 'Software Engineer (Wonderland & AI Effects) <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">Mar. 2023 - 2025</span>',
        description:
          `• Wonderland: Served as a core developer for the "Wallpaper Transition Effects" section of 'Wonderland' (Good Lock).<br />
           • <button type="button" class="vv-link text-primary hover:underline font-semibold" data-modal-open="vanillavibes-modal" aria-haspopup="dialog" aria-controls="vanillavibes-modal">VanillaVibes</button>: Built a shared RenderEffect-based AI visual effects rendering library for showcasing AI features across Galaxy phones, and drove its official integration starting with One UI 7.0; it has continued to evolve in active production ever since.<br />
           • Internal Graphic Libs: Optimized internal graphics library components, including Transparent Video Player and Skottie View, to improve rendering performance and runtime stability.`,
        icon: 'tabler:briefcase',
      },
      {
        title: 'Platform Software Engineer (Watch Face Studio) <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">Sep. 2020 - 2025</span>',
        description:
          `• Created WFF (Android Watch Face Format), an XML-based format defined by the XSD I authored, and built a validator for compatibility and quality checks.<br />
           • Participated in developing the Watch Face Studio preview rendering pipeline.<br />
           • Developed the WFF loader as the Wear OS watch face runtime; the Samsung-built runtime was later adopted into the Android platform and integrated into AOSP as an official runtime module.`,
        icon: 'tabler:briefcase',
      },
      {
        title: 'Android Graphics Engineer <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">Sep. 2019 - Sep. 2020</span>',
        description:
          `• Implemented 'Runtime Gradient Blur' (Patent Grade A) and multi-window blur effects.<br />
           • Proved window‑independent Android view blur via PoC and report; the methodology was later adopted in Samsung phones by the owning team.`,
        icon: 'tabler:brand-android',
      },
      {
        title: 'Tizen Graphics Engineer <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">Jul. 2018 - Sep. 2019</span>',
        description:
          `• Developed and optimized graphics using OpenGL ES and DALi Engine for Tizen wearables.<br />
           • Participated in the internal experimental project WatchFactory, a DALi-based 3D watchface tool for Tizen-based Samsung watches; it later evolved into Watch Face Studio.`,
        icon: 'tabler:device-watch',
      },
      {
        title: 'Mobile GPU Driver Engineer <br /> <span class="font-normal">Samsung Electronics</span> <br /> <span class="text-sm font-normal">Feb. 2016 - Jul. 2018</span>',
        description:
          `• Engineered ARM Mali GPU drivers for Samsung mobile products.<br />
           • Focused on driver stability, Khronos compliance, and performance tuning.<br />
           • Debugged complex GPU driver issues using low-level profiling tools.`,
        icon: 'tabler:cpu',
      },
      {
        title: 'Samsung Software Membership <br /> <span class="text-sm font-normal">Jan. 2014 - Jul. 2015</span>',
        description:
          `• Regular Member (24-1th) & Education Team Leader.<br />
           • Conducted seminars on 3D Programming (Vector, Matrix, Quaternion) and Algorithms.`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Education Widget ****************** -->

  <Steps
    id="education"
    title="Education"
    items={[
      {
        title: 'Bachelor of Science in Software Engineering & Applied Mathematics <br /> <span class="font-normal">Kumoh National Institute of Technology</span> <br /> <span class="text-sm font-normal">2008 - 2015</span>',
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Skills Widget ****************** -->

  <Features3
    title="Technical Skills"
    subtitle="A comprehensive overview of my technical capabilities."
    columns={3}
    classes={{ items: { container: 'skills-grid mt-10 max-w-5xl', panel: 'max-w-none w-full' } }}
    items={[
      {
        title: 'Languages',
        description: 'C++, Java, Kotlin, Python, C#, GLSL, TypeScript, HTML',
        icon: 'tabler:code',
      },
      {
        title: 'Graphics & GPU',
        description: 'OpenGL ES, Unity3D, Renderdoc, Mali Graphics Debugger',
        icon: 'tabler:cube',
      },
      {
        title: 'AI',
        description: 'Deep Learning, Generative AI, PyTorch, TensorFlow',
        icon: 'tabler:brain',
      },
      {
        title: 'Frameworks & Platforms',
        description: 'Android Framework, Android Wear, React, Electron, Vite',
        icon: 'tabler:device-mobile',
      },
      {
        title: 'Tools',
        description: 'Android Studio, Visual Studio Code, IntelliJ, Blender, Git, CI/CD pipelines',
        icon: 'tabler:tools',
      },
    ]}
  />

  <!-- Awards Widget ****************** -->

  <Content
    title="Honors & Awards"
    items={[
      {
        title: 'K-Hackathon 3: Grand Award (Minister Award)',
        description: 'Received the highest honor for "Team Globell" (Web-based global free internet phone service).',
      },
      {
        title: 'KIT Engineering Fair: Silver Award',
        description: 'Recognized for "Team Friendly Farm" (Farming simulation SNG).',
      },
      {
        title: 'HPCSS@UNIST: Outstanding Contribution Award',
        description: 'Awarded for "Team UIRI" (Simulation of double-slit experiment using Supercomputing).',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1562564055-71e051d33c19?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Awards Image',
    }}
  >
  </Content>

  <!-- VanillaVibes Modal ****************** -->

  <div id="vanillavibes-modal" class="vv-modal fixed inset-0 z-50 hidden" aria-hidden="true" data-modal>
    <div class="vv-backdrop absolute inset-0 z-0 bg-black/40 backdrop-blur-sm" data-modal-close></div>
    <div class="relative mx-auto my-8 max-w-5xl px-4 sm:px-6">
      <div
        class="vv-panel relative z-10 rounded-xl bg-white dark:bg-slate-900 shadow-xl border border-black/10 dark:border-white/10 pointer-events-auto"
        role="dialog"
        aria-modal="true"
        aria-label="VanillaVibes videos"
      >
        <div class="flex items-center justify-between px-4 sm:px-6 py-3 border-b border-black/10 dark:border-white/10">
          <div class="text-sm font-semibold text-gray-800 dark:text-slate-100">VanillaVibes</div>
          <button
            type="button"
            class="text-sm text-gray-500 hover:text-gray-800 dark:text-slate-400 dark:hover:text-slate-200"
            data-modal-close
          >
            Close
          </button>
        </div>
        <div class="grid gap-4 sm:gap-6 p-4 sm:p-6 md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
          <div class="vv-player-card rounded-lg bg-black/5 dark:bg-black/30 p-2 sm:p-3">
            <video
              id="vanillavibes-player"
              class="vv-player w-full max-w-full rounded-md bg-black object-contain"
              controls
              preload="metadata"
            ></video>
          </div>
          <div>
            <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-2">Clips</div>
            <ul class="space-y-2">
              {
                vanillaVibesVideos.map((video, index) => (
                  <li>
                    <button
                      type="button"
                      class={`vv-item w-full text-left rounded-md px-3 py-2 text-sm border border-black/10 dark:border-white/10 ${
                        index === 0 ? 'is-active' : ''
                      }`}
                      data-vv-src={video.src}
                    >
                      {video.label}
                    </button>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

</Layout>

<script is:inline>
  const syncMetaLogoTheme = () => {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('.meta-logo svg').forEach((svg) => {
      svg.classList.toggle('dark', isDark);
      svg.classList.toggle('light', !isDark);
    });
  };

  syncMetaLogoTheme();

  const observer = new MutationObserver(syncMetaLogoTheme);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  const initVanillaVibesModal = () => {
    const modal = document.getElementById('vanillavibes-modal');
    if (!modal || modal.dataset.vvBound === 'true') return;
    const player = modal.querySelector('#vanillavibes-player');
    if (!player) return;

    modal.dataset.vvBound = 'true';

    const getButtons = () => Array.from(modal.querySelectorAll('[data-vv-src]'));

    const setActiveVideo = (button, shouldPlay = false) => {
      if (!button || !player) return;
      const buttons = getButtons();
      buttons.forEach((btn) => btn.classList.remove('is-active'));
      button.classList.add('is-active');
      const src = button.getAttribute('data-vv-src');
      if (src) {
        player.src = src;
        player.load();
        if (shouldPlay) {
          player.play().catch(() => {});
        }
      }
    };

    const resetPlayer = () => {
      if (!player) return;
      player.pause();
      player.removeAttribute('src');
      player.load();
    };

    modal.addEventListener('modal:open', () => {
      const buttons = getButtons();
      setActiveVideo(buttons[0], false);
    });
    modal.addEventListener('modal:close', resetPlayer);

    modal.addEventListener('click', (event) => {
      const button = event.target.closest('[data-vv-src]');
      if (button) {
        setActiveVideo(button, true);
      }
    });
  };

  initVanillaVibesModal();
  document.addEventListener('astro:after-swap', initVanillaVibesModal);
</script>

<style>
  @media (min-width: 1024px) {
    .skills-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr)) !important;
    }

    .skills-grid > * {
      grid-column: span 2 / span 2;
    }

    .skills-grid > *:nth-last-child(2) {
      grid-column-start: 2;
    }

    .skills-grid > *:last-child {
      grid-column-start: 4;
    }
  }

  .vv-modal {
    pointer-events: auto;
  }

  .vv-panel,
  .vv-panel * {
    pointer-events: auto;
  }

  .vv-modal:not(.hidden) {
    display: flex;
    align-items: center;
  }

  .vv-item {
    color: #1f2937;
    background: #ffffff;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .vv-item.is-active {
    background: #eff6ff;
    border-color: #93c5fd;
    color: #1d4ed8;
  }

  .vv-player-card {
    min-height: 240px;
    display: grid;
    place-items: center;
  }

  .vv-player {
    width: 100%;
    max-width: 100%;
    height: auto;
    max-height: 420px;
    aspect-ratio: 16 / 9;
  }

  :global(html.dark) .vv-item {
    background: #0f172a;
    color: #e2e8f0;
  }

  :global(html.dark) .vv-item.is-active {
    background: #0b1220;
    border-color: #1d4ed8;
    color: #bfdbfe;
  }
</style>
